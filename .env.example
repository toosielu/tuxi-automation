SUPABASE_DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=replace-with-your-password
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=replace-with-your-anon-key

# AI model config. Keep provider=local if you only want the built-in template fallback.
TUXI_AI_PROVIDER=openai-compatible
TUXI_AI_API_KEY=replace-with-your-model-api-key
TUXI_AI_BASE_URL=https://api.openai.com/v1
TUXI_AI_MODEL=gpt-4o-mini
TUXI_AI_TIMEOUT_SECONDS=60

# DeepSeek example:
# TUXI_AI_BASE_URL=https://api.deepseek.com/v1
# TUXI_AI_MODEL=deepseek-chat

# SiliconFlow example:
# TUXI_AI_BASE_URL=https://api.siliconflow.cn/v1
# TUXI_AI_MODEL=Qwen/Qwen2.5-72B-Instruct
